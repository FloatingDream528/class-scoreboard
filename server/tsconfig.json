  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "outDir": "../dist-server",
    "rootDir": "..",
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": false
